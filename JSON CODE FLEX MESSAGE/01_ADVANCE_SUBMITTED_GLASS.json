{
  "type": "flex",
  "altText": "มีคำขอเบิกเงินใหม่ - {advNo}",
  "contents": {
    "type": "bubble",
    "size": "mega",
    "styles": {
      "body": {
        "backgroundColor": "#0A1211"
      }
    },
    "body": {
      "type": "box",
      "layout": "vertical",
      "paddingAll": "0px",
      "contents": [
        {
          "type": "box",
          "layout": "vertical",
          "position": "absolute",
          "width": "100%",
          "height": "100%",
          "background": {
            "type": "linearGradient",
            "angle": "145deg",
            "startColor": "#08100F",
            "endColor": "#142220"
          },
          "contents": []
        },
        {
          "type": "box",
          "layout": "vertical",
          "position": "absolute",
          "width": "220px",
          "height": "220px",
          "cornerRadius": "110px",
          "offsetTop": "-60px",
          "offsetStart": "-60px",
          "background": {
            "type": "linearGradient",
            "angle": "0deg",
            "startColor": "#4E958D1A",
            "endColor": "#4E958D44"
          },
          "contents": []
        },
        {
          "type": "box",
          "layout": "vertical",
          "position": "absolute",
          "width": "240px",
          "height": "240px",
          "cornerRadius": "120px",
          "offsetBottom": "-80px",
          "offsetEnd": "-80px",
          "background": {
            "type": "linearGradient",
            "angle": "0deg",
            "startColor": "#007AFF1A",
            "endColor": "#007AFF33"
          },
          "contents": []
        },
        {
          "type": "box",
          "layout": "vertical",
          "paddingAll": "24px",
          "spacing": "lg",
          "contents": [
            {
              "type": "box",
              "layout": "horizontal",
              "alignItems": "center",
              "contents": [
                {
                  "type": "box",
                  "layout": "vertical",
                  "contents": [
                    {
                      "type": "text",
                      "text": "ADVANCE PRO",
                      "color": "#94A3B8",
                      "size": "xs",
                      "weight": "bold"
                    },
                    {
                      "type": "text",
                      "text": "มีคำขอเบิกเงินใหม่",
                      "color": "#FFFFFF",
                      "size": "lg",
                      "weight": "bold",
                      "margin": "xs"
                    }
                  ],
                  "flex": 8
                },
                {
                  "type": "box",
                  "layout": "vertical",
                  "backgroundColor": "#D9770626",
                  "cornerRadius": "999px",
                  "paddingTop": "4px",
                  "paddingBottom": "4px",
                  "paddingStart": "10px",
                  "paddingEnd": "10px",
                  "contents": [
                    {
                      "type": "text",
                      "text": "รออนุมัติ",
                      "color": "#FBBF24",
                      "size": "xs",
                      "weight": "bold",
                      "align": "center"
                    }
                  ],
                  "flex": 4
                }
              ]
            },
            {
              "type": "box",
              "layout": "vertical",
              "backgroundColor": "#FFFFFF0D",
              "borderColor": "#FFFFFF1F",
              "borderWidth": "1px",
              "cornerRadius": "24px",
              "paddingAll": "20px",
              "spacing": "md",
              "contents": [
                {
                  "type": "box",
                  "layout": "horizontal",
                  "contents": [
                    {
                      "type": "text",
                      "text": "เลขที่ใบเบิก",
                      "color": "#94A3B8",
                      "size": "xs"
                    },
                    {
                      "type": "text",
                      "text": "{advNo}",
                      "color": "#4E958D",
                      "size": "sm",
                      "weight": "bold",
                      "align": "end"
                    }
                  ]
                },
                {
                  "type": "box",
                  "layout": "vertical",
                  "backgroundColor": "#FFFFFF08",
                  "borderColor": "#FFFFFF0F",
                  "borderWidth": "1px",
                  "cornerRadius": "16px",
                  "paddingAll": "16px",
                  "contents": [
                    {
                      "type": "text",
                      "text": "ยอดขอเบิก",
                      "color": "#94A3B8",
                      "size": "xs",
                      "align": "center",
                      "weight": "bold"
                    },
                    {
                      "type": "text",
                      "text": "{requestedAmount}",
                      "color": "#FFFFFF",
                      "size": "xxl",
                      "weight": "bold",
                      "align": "center",
                      "margin": "xs"
                    },
                    {
                      "type": "text",
                      "text": "บาท",
                      "color": "#94A3B8",
                      "size": "xs",
                      "align": "center",
                      "margin": "xs"
                    }
                  ]
                },
                {
                  "type": "separator",
                  "color": "#FFFFFF14"
                },
                {
                  "type": "box",
                  "layout": "vertical",
                  "spacing": "xs",
                  "contents": [
                    {
                      "type": "text",
                      "text": "รายละเอียด",
                      "color": "#4E958D",
                      "size": "xs",
                      "weight": "bold"
                    },
                    {
                      "type": "box",
                      "layout": "horizontal",
                      "margin": "sm",
                      "contents": [
                        {
                          "type": "text",
                          "text": "ผู้เบิก",
                          "color": "#94A3B8",
                          "size": "xs",
                          "flex": 5
                        },
                        {
                          "type": "text",
                          "text": "{employeeName}",
                          "color": "#FFFFFF",
                          "size": "xs",
                          "weight": "bold",
                          "align": "end",
                          "flex": 7
                        }
                      ]
                    },
                    {
                      "type": "box",
                      "layout": "horizontal",
                      "contents": [
                        {
                          "type": "text",
                          "text": "โครงการ",
                          "color": "#94A3B8",
                          "size": "xs",
                          "flex": 5
                        },
                        {
                          "type": "text",
                          "text": "{projectName}",
                          "color": "#FFFFFF",
                          "size": "xs",
                          "weight": "bold",
                          "align": "end",
                          "flex": 7
                        }
                      ]
                    },
                    {
                      "type": "box",
                      "layout": "horizontal",
                      "contents": [
                        {
                          "type": "text",
                          "text": "รายละเอียด",
                          "color": "#94A3B8",
                          "size": "xs",
                          "flex": 5
                        },
                        {
                          "type": "text",
                          "text": "{purpose}",
                          "color": "#FFFFFF",
                          "size": "xs",
                          "weight": "bold",
                          "align": "end",
                          "flex": 7
                        }
                      ]
                    },
                    {
                      "type": "box",
                      "layout": "horizontal",
                      "contents": [
                        {
                          "type": "text",
                          "text": "บัญชีรับเงิน",
                          "color": "#94A3B8",
                          "size": "xs",
                          "flex": 5
                        },
                        {
                          "type": "text",
                          "text": "{bankName} {bankAccountNo}",
                          "color": "#FFFFFF",
                          "size": "xs",
                          "weight": "bold",
                          "align": "end",
                          "flex": 7
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "box",
              "layout": "vertical",
              "spacing": "sm",
              "contents": [
                {
                  "type": "button",
                  "height": "sm",
                  "style": "primary",
                  "color": "#16A34A",
                  "action": {
                    "type": "uri",
                    "label": "อนุมัติ",
                    "uri": "{liffApproveUrl}"
                  }
                },
                {
                  "type": "button",
                  "height": "sm",
                  "style": "primary",
                  "color": "#EF4444",
                  "action": {
                    "type": "uri",
                    "label": "ไม่อนุมัติ",
                    "uri": "{liffRejectUrl}"
                  }
                },
                {
                  "type": "button",
                  "height": "sm",
                  "style": "link",
                  "color": "#94A3B8",
                  "action": {
                    "type": "uri",
                    "label": "ดูรายละเอียด",
                    "uri": "{liffDetailUrl}"
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
